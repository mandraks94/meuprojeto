{
  "manifest_version": 3,
  "name": "IG Tools Pro",
  "version": "1.0",
  "description": "Ferramentas avançadas para Instagram: Download, Modo Anônimo e Gestão de Seguidores.",
  "permissions": [
    "storage"
  ],
  "action": {},
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}